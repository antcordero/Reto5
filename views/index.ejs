<div class="row justify-content-center">
    <div class="col-md-8">

        <div class="card mb-4">
            <div class="card-body text-center">
                <h2 class="h5 mb-4" style="color: var(--color-texto-suave); text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem;">
                    Estado del vehículo
                </h2>

                <div id="info-panel" class="d-none mb-4">
                    <div class="d-flex justify-content-center gap-5 mb-3">
                        <div>
                            <div class="metrica-valor"><span id="distancia">0</span><small style="font-size:1rem">m</small></div>
                            <div class="metrica-label">Distancia</div>
                        </div>
                        <div style="width:1px; background: var(--color-borde);"></div>
                        <div>
                            <div class="metrica-valor"><span id="tiempo">0</span><small style="font-size:1rem">min</small></div>
                            <div class="metrica-label">Tiempo aparcado</div>
                        </div>
                    </div>
                </div>

                <button id="btn-aparcar" class="btn btn-primary btn-lg w-100 mb-3">
                    📌 Aparcar aquí
                </button>
                <button id="btn-retirar" class="btn btn-lg w-100 d-none">
                    ✅ Ya tengo el coche
                </button>
            </div>
        </div>

        <div class="card">
            <div class="card-body p-0">
                <div id="map"></div>
            </div>
        </div>

    </div>
</div>
