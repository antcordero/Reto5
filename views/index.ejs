<div class="row justify-content-center">
  <div class="col-md-8">

      <div class="card shadow-sm mb-4">
          <div class="card-body text-center">
              <h2 class="h4 mb-3">¿Dónde está tu coche?</h2>

              <div id="info-panel" class="d-none alert alert-info">
                  <p class="mb-1"><strong>Distancia:</strong> <span id="distancia">Calculando...</span> metros</p>
                  <p class="mb-0"><strong>Tiempo aparcado:</strong> <span id="tiempo">0</span> minutos</p>
              </div>

              <button id="btn-aparcar" class="btn btn-primary btn-lg w-100 mb-2">
                  Aparcar aquí
              </button>
              <button id="btn-retirar" class="btn btn-success btn-lg w-100 d-none">
                  Ya tengo el coche
              </button>
          </div>
      </div>

      <div class="card shadow-sm">
          <div class="card-body p-0">
              <div id="map" style="height: 400px; width: 100%; border-radius: 0.375rem;"></div>
          </div>
      </div>

  </div>
</div>
