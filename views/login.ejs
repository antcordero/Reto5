<div class="login-card">
    <div class="card">
        <div class="card-body">
            <h2 class="text-center mb-1" style="font-size: 1.4rem;">Bienvenido</h2>
            <p class="text-center mb-4" style="color: var(--color-texto-suave); font-size: 0.85rem;">
                Accede o crea una cuenta nueva
            </p>

            <% if (typeof error !== 'undefined') { %>
            <div class="alert alert-danger py-2 mb-3" style="font-size:0.85rem;"><%= error %></div>
            <% } %>

            <form action="/acceso" method="POST">
                <div class="mb-3">
                    <label class="form-label">Nombre de usuario</label>
                    <input type="text" class="form-control" name="username" required autofocus>
                </div>
                <div class="mb-4">
                    <label class="form-label">Contraseña</label>
                    <input type="password" class="form-control" name="password" required>
                </div>
                <button type="submit" class="btn w-100 mb-2" style="background: var(--color-acento); color: white; border-radius: 10px; padding: 12px; font-weight: 600;">
                    Entrar / Crear cuenta
                </button>
                <a href="/" class="btn w-100" style="border: 1px solid var(--color-borde); color: var(--color-texto-suave); border-radius: 10px; padding: 12px;">
                    Continuar sin cuenta
                </a>
            </form>

            <p class="text-center mt-3" style="color: var(--color-texto-suave); font-size: 0.78rem;">
                Si no tienes cuenta se creará automáticamente al entrar.
            </p>
        </div>
    </div>
</div>
